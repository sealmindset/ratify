# =============================================================================
# Ratify -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Placeholders (replaced during /make-it build phase):
#   Ratify          - human-readable app name
#   ratify          - kebab-case app name
#   3100     - host port for frontend (e.g., 3100)
#   8000      - host port for backend (e.g., 8100)
#   5500           - host port for PostgreSQL (e.g., 5500)
#   10090    - host port for mock-oidc (e.g., 10190)
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ratify:ratify@localhost:5500/ratify

# ---------------------------------------------------------------------------
# OIDC Authentication
# ---------------------------------------------------------------------------
# For local development, these point to the mock-oidc container.
# For production, replace with your Azure AD / Entra ID values.
OIDC_ISSUER_URL=http://localhost:10090
OIDC_CLIENT_ID=mock-oidc-client
OIDC_CLIENT_SECRET=mock-oidc-secret

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3100
BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
ENFORCE_SECRETS=false

# ---------------------------------------------------------------------------
# Jira Integration
# ---------------------------------------------------------------------------
# Local development (mock-jira)
JIRA_BASE_URL=http://localhost:8543
JIRA_AUTH_TOKEN=mock-jira-token
# Production (uncomment and set real values)
# JIRA_BASE_URL=https://jira.example.com
# JIRA_AUTH_TOKEN=<your-jira-api-token>

# ---------------------------------------------------------------------------
# AI Provider
# ---------------------------------------------------------------------------
AI_PROVIDER=anthropic_foundry
AI_MODEL_HEAVY=claude-opus-4-6
AI_MODEL_STANDARD=claude-sonnet-4-6
AI_MODEL_LIGHT=claude-haiku-4-5

# Azure AI Foundry (if AI_PROVIDER=anthropic_foundry)
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=

# Direct Anthropic (if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=

# OpenAI (if AI_PROVIDER=openai)
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# AI Operational Safety
# ---------------------------------------------------------------------------
AI_RATE_LIMIT_REQUESTS_PER_MINUTE=20
AI_RATE_LIMIT_TOKENS_PER_MINUTE=50000
AI_MAX_PROMPT_CHARS=100000

# ---------------------------------------------------------------------------
# Activity Log
# ---------------------------------------------------------------------------
LOG_BUFFER_SIZE=10000
# Future: Cribl Stream forwarding
# CRIBL_STREAM_URL=
# CRIBL_STREAM_TOKEN=
